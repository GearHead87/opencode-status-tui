{
  "name": "opencode-status-tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "opencode-status-tui": "dist/opencode-status-tui"
  },
  "scripts": {
    "build": "bun run build:linux",
    "build:linux": "mkdir -p dist && bun build ./src/index.tsx --compile --target=bun-linux-x64 --outfile ./dist/opencode-status-tui",
    "dev": "bun --watch src/index.tsx",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "start": "./dist/opencode-status-tui",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "ink": "^5.0.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.2.66",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "react-devtools-core": "^6.1.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "packageManager": "bun@1.3.10"
}
